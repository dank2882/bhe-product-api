{
  "openapi": "3.1.0",
  "info": {
    "title": "Church Song Catalog API",
    "version": "2.0.0",
    "description": "Slice 2 action schema for searching the canonical hymnal catalog with ministry metadata filters and retrieving canonical song details."
  },
  "servers": [
    {
      "url": "https://bhe-product-api-265001256563.us-west1.run.app"
    }
  ],
  "paths": {
    "/songs/search": {
      "post": {
        "operationId": "searchSongs",
        "summary": "Search the canonical hymnal catalog using free text, structured filters, or both",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchSongsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Matching songs returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchSongsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing query or filters, or invalid filter values",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Song search failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/songs/{songId}": {
      "get": {
        "operationId": "getSong",
        "summary": "Get a canonical song record by songId",
        "parameters": [
          {
            "name": "songId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Song returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetSongResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid songId",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Song not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Song fetch failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SearchSongsRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Optional free-text query for titles, aliases, or topics."
          },
          "filters": {
            "$ref": "#/components/schemas/SearchSongFilters"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 25,
            "default": 10
          },
          "sort": {
            "type": "string",
            "enum": [
              "relevance",
              "title_asc",
              "hymnal_number_asc"
            ],
            "default": "relevance"
          }
        },
        "anyOf": [
          {
            "required": [
              "query"
            ]
          },
          {
            "required": [
              "filters"
            ]
          }
        ]
      },
      "SearchSongFilters": {
        "type": "object",
        "properties": {
          "theme": {
            "type": "string",
            "description": "Topic filter such as Trust or Adoration and Praise."
          },
          "hymnalNumber": {
            "type": "integer",
            "minimum": 1
          },
          "sourceStatus": {
            "type": "string",
            "enum": [
              "verified",
              "needs_review",
              "blocked"
            ]
          },
          "leaderReadiness": {
            "$ref": "#/components/schemas/LeaderReadiness"
          },
          "strength": {
            "$ref": "#/components/schemas/Strength"
          },
          "feelsDated": {
            "$ref": "#/components/schemas/FeelsDated"
          },
          "situationalUse": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/SituationalUse"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/SituationalUse"
                }
              }
            ],
            "description": "Exact ministry-use metadata tags. Use only supported values."
          },
          "developmentPotential": {
            "$ref": "#/components/schemas/DevelopmentPotential"
          }
        }
      },
      "SearchSongsResponse": {
        "type": "object",
        "required": [
          "ok",
          "count",
          "songs"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "query": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "songs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SongSummary"
            }
          },
          "appliedFilters": {
            "$ref": "#/components/schemas/SearchSongFilters"
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SongSummary": {
        "type": "object",
        "required": [
          "songId",
          "hymnalNumber",
          "canonicalTitle",
          "topics",
          "ministryMetadata",
          "sourceStatus",
          "reviewFlags"
        ],
        "properties": {
          "songId": {
            "type": "string"
          },
          "hymnalNumber": {
            "type": "integer"
          },
          "canonicalTitle": {
            "type": "string"
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ministryMetadata": {
            "$ref": "#/components/schemas/MinistryMetadata"
          },
          "sourceStatus": {
            "type": "string"
          },
          "reviewFlags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "GetSongResponse": {
        "type": "object",
        "required": [
          "ok",
          "song"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "song": {
            "$ref": "#/components/schemas/SongDetail"
          }
        }
      },
      "SongDetail": {
        "type": "object",
        "required": [
          "songId",
          "hymnalId",
          "hymnalNumber",
          "canonicalTitle",
          "topics",
          "titleAliases",
          "normalizedLookupKeys",
          "ministryMetadata",
          "sourceStatus",
          "sourceEvidence",
          "reviewFlags",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "songId": {
            "type": "string"
          },
          "hymnalId": {
            "type": "string"
          },
          "hymnalNumber": {
            "type": "integer"
          },
          "canonicalTitle": {
            "type": "string"
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "titleAliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "normalizedLookupKeys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ministryMetadata": {
            "$ref": "#/components/schemas/MinistryMetadata"
          },
          "sourceStatus": {
            "type": "string"
          },
          "sourceEvidence": {
            "type": "object"
          },
          "reviewFlags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "MinistryMetadata": {
        "type": "object",
        "required": [
          "leaderReadiness",
          "strength",
          "feelsDated",
          "situationalUse",
          "developmentPotential"
        ],
        "properties": {
          "leaderReadiness": {
            "$ref": "#/components/schemas/LeaderReadiness"
          },
          "strength": {
            "$ref": "#/components/schemas/Strength"
          },
          "feelsDated": {
            "$ref": "#/components/schemas/FeelsDated"
          },
          "situationalUse": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SituationalUse"
            }
          },
          "developmentPotential": {
            "$ref": "#/components/schemas/DevelopmentPotential"
          }
        }
      },
      "LeaderReadiness": {
        "type": "string",
        "enum": [
          "ready_now",
          "learnable_soon",
          "not_ready",
          "unknown"
        ]
      },
      "Strength": {
        "type": "string",
        "enum": [
          "core",
          "solid_rotation",
          "situational",
          "unknown"
        ]
      },
      "FeelsDated": {
        "type": "string",
        "enum": [
          "yes",
          "no",
          "mixed",
          "unknown"
        ]
      },
      "SituationalUse": {
        "type": "string",
        "enum": [
          "invitation",
          "reflective",
          "revival"
        ]
      },
      "DevelopmentPotential": {
        "type": "string",
        "enum": [
          "high",
          "medium",
          "low",
          "unknown"
        ]
      },
      "ErrorObject": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "ok",
          "error"
        ],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": false
          },
          "error": {
            "$ref": "#/components/schemas/ErrorObject"
          }
        }
      }
    }
  }
}
